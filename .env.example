# ════════════════════════════════════════════════════════════
# milkia-backend — environment template (staging defaults)
# Copy to .env locally, or paste into Coolify → Environment Variables.
# Mark every line ending in (secret) as encrypted in Coolify.
# ════════════════════════════════════════════════════════════

# ─── 1. App-wide ─────────────────────────────────────────────
# NODE_ENV stays "production" so Nest/Express enable prod-mode
# optimisations. Use APP_ENV to label staging vs prod separately.
NODE_ENV=production
APP_ENV=staging

# Port the API listens on. Coolify routes traffic here.
API_PORT=4000

# ─── 2. Database ─────────────────────────────────────────────
# Internal hostname inside the Coolify network. Append ?sslmode=require
# if you switch to a managed Postgres outside the cluster.
DATABASE_URL=postgres://postgres:CHANGE_ME@INTERNAL_HOSTNAME:5432/postgres   # (secret)

# ─── 3. Auth ────────────────────────────────────────────────
# Long random string. Rotating logs every user out instantly.
# Generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_openssl_rand_hex_64                                     # (secret)

# ─── 4. Twilio Verify (OTP for tenants + password reset) ─────
# https://console.twilio.com/us1/develop/verify/services
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx                        # (secret)
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx                           # (secret)
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx                 # (secret)
TWILIO_VERIFY_CHANNEL=sms

# Staging-only. When TRUE the API skips the real Twilio SMS and accepts
# the static code "000000" for any phone — useful for QA without burning
# real SMS credits. NEVER set TRUE in production.
TWILIO_DEV_BYPASS=true

# ─── 5. Invoicing / ZATCA e-invoice ──────────────────────────
# Encrypts ZATCA private keys + CSID secrets at rest in the DB.
# Rotating without a re-encryption migration makes existing rows
# undecryptable — DO NOT rotate in production casually.
# Generate with: openssl rand -base64 32
APP_ENCRYPTION_KEY=CHANGE_ME_openssl_rand_base64_32                          # (secret)

# Optional: 1 to log every ZATCA gateway request/response.
# ZATCA_DEBUG=1

# Optional: Chrome path for headless PDF rendering. Auto-detected if unset.
# CHROME_PATH=/usr/bin/google-chrome
