# ════════════════════════════════════════════════════════════════════════════
#  apps/api/.env — backend (NestJS) env vars.
#  Copy to .env locally. In production set these in the DO App Platform UI
#  (Settings → Environment Variables) — never commit real values.
# ════════════════════════════════════════════════════════════════════════════

# DB — local Postgres in dev, DO managed PG in prod (sslmode=require auto-detected)
DATABASE_URL=postgresql://milkia:milkia@localhost:5432/milkia

# JWT — long random string. Rotating it logs everyone out.
JWT_SECRET=replace-me-with-a-long-random-secret

# HTTP port the NestJS app listens on. DO sets PORT, our app reads API_PORT.
API_PORT=4000

# Twilio Verify (tenant phone OTP + password reset)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_VERIFY_CHANNEL=sms

# ─── Invoice / ZATCA ─────────────────────────────────────────────────────
# Generate with: `openssl rand -base64 32`
# Used to encrypt ZATCA private keys + CSID secrets at rest. Rotating it
# without a migration step makes existing rows undecryptable — DO NOT rotate
# in production unless you have a re-encryption plan.
APP_ENCRYPTION_KEY=replace-me-with-openssl-rand-base64-32

# Optional: set ZATCA_DEBUG=1 to log every gateway request
# ZATCA_DEBUG=1

# Optional: explicit Chrome path for headless PDF rendering. Leave unset to
# autodetect (looks in standard /Applications/* and /usr/bin/* locations).
# CHROME_PATH=/usr/bin/google-chrome
