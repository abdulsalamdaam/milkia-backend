# ════════════════════════════════════════════════════════════
# milkia-backend — environment template (staging defaults)
# Copy to .env locally, or paste into Coolify → Environment Variables.
# Mark every line ending in (secret) as encrypted in Coolify.
# ════════════════════════════════════════════════════════════

# ─── 1. App-wide ─────────────────────────────────────────────
# NODE_ENV stays "production" so Nest/Express enable prod-mode
# optimisations. Use APP_ENV to label staging vs prod separately.
NODE_ENV=production
APP_ENV=staging

# Port the API listens on. Coolify routes traffic here.
API_PORT=4000

# ─── 2. Database ─────────────────────────────────────────────
# Internal hostname inside the Coolify network. Append ?sslmode=require
# if you switch to a managed Postgres outside the cluster.
DATABASE_URL=postgres://postgres:CHANGE_ME@INTERNAL_HOSTNAME:5432/postgres   # (secret)

# ─── 3. Auth ────────────────────────────────────────────────
# Long random string. Rotating logs every user out instantly.
# Generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_openssl_rand_hex_64                                     # (secret)

# ─── 4. Twilio Verify (OTP for tenants + password reset) ─────
# https://console.twilio.com/us1/develop/verify/services
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx                        # (secret)
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx                           # (secret)
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx                 # (secret)
TWILIO_VERIFY_CHANNEL=sms

# Staging-only. When TRUE the API skips the real Twilio SMS and accepts
# the static code "000000" for any phone — useful for QA without burning
# real SMS credits. NEVER set TRUE in production.
TWILIO_DEV_BYPASS=true

# NOTE: The tenant mobile-app OTP flow is hardcoded to bypass SMS and
# accept the code "1234" while the team is testing builds. Re-enable real
# Twilio SMS by editing src/modules/auth/auth.service.ts (search for
# "SMS paused").

# ─── 5. Invoicing / ZATCA e-invoice ──────────────────────────
# Encrypts ZATCA private keys + CSID secrets at rest in the DB.
# Rotating without a re-encryption migration makes existing rows
# undecryptable — DO NOT rotate in production casually.
# Generate with: openssl rand -base64 32
APP_ENCRYPTION_KEY=CHANGE_ME_openssl_rand_base64_32                          # (secret)

# Optional: 1 to log every ZATCA gateway request/response.
# ZATCA_DEBUG=1

# Optional: Chrome path for headless PDF rendering. Auto-detected if unset.
# CHROME_PATH=/usr/bin/google-chrome

# ─── 6. MinIO / S3 uploads ───────────────────────────────────
# S3-compatible object storage. Used by UploadsService for any file
# the API persists (maintenance attachments, profile avatars, ...).
MINIO_ENDPOINT=https://s3.oqudk.com
MINIO_REGION=us-east-1
MINIO_BUCKET=uploads
MINIO_ACCESS_KEY=CHANGE_ME                                                   # (secret)
MINIO_SECRET_KEY=CHANGE_ME                                                   # (secret)

# Default lifetime of pre-signed GET/PUT URLs (seconds). 15 min is plenty
# for browser playback / form posts. Override per-call if a longer link
# is needed.
MINIO_PRESIGN_TTL=900

# Optional: if the bucket is fronted by a public CDN/base URL, set it here
# and UploadsService.publicUrl(key) will return that URL instead of empty.
# Leave blank to force pre-signed URLs everywhere.
# MINIO_PUBLIC_URL_BASE=https://cdn.oqudk.com/uploads

# ─── 7. Resend email ─────────────────────────────────────────
# https://resend.com/api-keys — domain in `RESEND_FROM` must be verified.
RESEND_API_KEY=re_CHANGE_ME                                                  # (secret)
RESEND_FROM=Oqudk <hello@oqudk.com>

# Default Reply-To. Avoid noreply@ — recipients can't reply, and major
# clients (Gmail, Outlook) downscore senders that drop the header.
RESEND_REPLY_TO=hello@oqudk.com

# One-click List-Unsubscribe (RFC 8058). The URL must accept a POST with
# no body; the mailto must route to a real inbox. Both improve mail-tester
# score and keep us inside Gmail's bulk-sender requirements.
LIST_UNSUBSCRIBE_URL=https://oqudk.com/email/unsubscribe
LIST_UNSUBSCRIBE_MAILTO=unsubscribe@oqudk.com

# Where admin-facing notifications (new maintenance ticket, new contact
# submission) are sent. Multiple recipients can be added later by changing
# the EmailService templates.
ADMIN_NOTIFY_EMAIL=abdulsalam@daam.sa
